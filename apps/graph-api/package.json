{
    "name": "graph-api",
    "version": "1.4.1",
    "private": true,
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "yarn build-types",
        "build-types": "rm -rf ./dist && tsc -b",
        "start": "node dist/index.js",
        "dev": "nodemon --exec node -r ts-node/register --env-file=.env ./src/index.ts",
        "semantic-release": "node ../../node_modules/semantic-release/bin/semantic-release.js"
    },
    "dependencies": {
        "@aws-sdk/client-bedrock-agent": "^3.1075.0",
        "@aws-sdk/client-bedrock-agent-runtime": "^3.1075.0",
        "@aws-sdk/client-bedrock-runtime": "^3.1075.0",
        "@aws-sdk/client-opensearchserverless": "^3.1075.0",
        "@aws-sdk/client-s3": "^3.1075.0",
        "body-parser": "^2.2.2",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^24.0.1",
        "copyfiles": "^2.4.1",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^6.0.3"
    }
}
