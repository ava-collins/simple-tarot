{
    "name": "graph-api",
    "version": "1.4.0",
    "private": true,
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "yarn build-types",
        "build-types": "rm -rf ./dist && tsc -b",
        "postbuild": "copyfiles -u 1 'src/**/*.graphql' dist/",
        "start": "node dist/index.js",
        "dev": "nodemon --exec node -r ts-node/register --env-file=.env ./src/index.ts",
        "run-db": "docker run --name graph --restart always --env-file=.db.env -p 7474:7474 -p 7687:7687 -v $(pwd)/data:/data -d neo4j:2025.05.0",
        "stop-db": "docker stop graph && docker rm graph",
        "generate": "graphql-codegen",
        "migrate:normalize": "node -r ts-node/register src/migrations/normalize-graph-data.ts",
        "migrate:constraints": "node -r ts-node/register src/migrations/create-constraints.ts",
        "semantic-release": "node ../../node_modules/semantic-release/bin/semantic-release.js"
    },
    "dependencies": {
        "@apollo/datasource-rest": "^6.4.1",
        "@apollo/server": "^5.5.1",
        "@as-integrations/express5": "^1.1.2",
        "@neo4j/graphql": "^7.5.3",
        "body-parser": "^2.2.2",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "graphql": "^16.14.0",
        "graphql-tag": "^2.12.6",
        "neo4j-driver": "^6.0.1",
        "serpapi": "^2.1.0"
    },
    "devDependencies": {
        "@graphql-codegen/cli": "^7.1.2",
        "@graphql-codegen/typescript": "^4.1.6",
        "@graphql-codegen/typescript-resolvers": "^6.0.2",
        "@types/body-parser": "^1.19.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^24.0.1",
        "copyfiles": "^2.4.1",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^6.0.3"
    }
}
