{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "module": "commonjs",
        "noEmit": false,
        "outDir": "dist",
        "rootDir": ".",
        "target": "ES2022",
        "ignoreDeprecations": "6.0",
        "types": ["node"]
    },
    "include": ["src/**/*", "scripts/**/*"],
    "exclude": ["dist/**", "node_modules", "**/*.test.ts"]
}
