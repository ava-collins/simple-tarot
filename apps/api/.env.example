PORT=4100
HOST=localhost

# Use local mode for offline development. Use "bedrock" after the Bedrock stack
# has deployed and the values below are populated from CloudFormation outputs.
BEDROCK_RUNTIME_MODE=local
BEDROCK_REGION=us-east-1
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_MODEL_ID=
BEDROCK_MODEL_ARN=
BEDROCK_INFERENCE_PROFILE_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_INFERENCE_PROFILE_ARN=
BEDROCK_MAX_ATTEMPTS=5
BEDROCK_RETRIEVAL_RESULTS=5

# Auth and persistence (required for local authenticated testing)
# API_AUTH_MODE=cognito
# COGNITO_ISSUER=
# COGNITO_CLIENT_ID=
# USER_DATA_TABLE_NAME=
# API_LOG_BUCKET_NAME=

# Avatar image search
# SERPAPI_API_KEY=
