PORT=4100
HOST=localhost

# The deployed application uses Bedrock in us-east-2. Populate the knowledge
# base and application inference profile ARN from CloudFormation outputs.
# Set BEDROCK_RUNTIME_MODE=local only for offline development.
BEDROCK_RUNTIME_MODE=bedrock
BEDROCK_REGION=us-east-2
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_MODEL_ID=
BEDROCK_MODEL_ARN=
BEDROCK_INFERENCE_PROFILE_ID=
BEDROCK_INFERENCE_PROFILE_ARN=
BEDROCK_MAX_ATTEMPTS=5
BEDROCK_RETRIEVAL_RESULTS=5

# Auth and persistence (required for local authenticated testing)
# API_AUTH_MODE=cognito
# COGNITO_ISSUER=
# COGNITO_CLIENT_ID=
# USER_DATA_TABLE_NAME=
# API_LOG_BUCKET_NAME=

# Avatar image search
# SERPAPI_API_KEY=
