{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": false,
        "noEmit": false,
        "esModuleInterop": true,
        "module": "esnext",
        "target": "ES2017",
        "allowJs": true,
        "outDir": "dist",
        "rootDir": ".",
        "ignoreDeprecations": "6.0"
    },
    "include": ["src/**/*", "index.tsx", "card-names.ts"],
    "exclude": [
        "**/*.js",
        "node_modules",
        "dist/**",
        "coverage/**",
        "**/*.test.ts",
        "**/*.test.tsx"
    ]
}
