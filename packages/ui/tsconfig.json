{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "ignoreDeprecations": "6.0",
        "noEmit": false,
        "noImplicitAny": false,
        "outDir": "dist",
        "rootDir": "."
    },
    "include": ["**/*.ts", "**/*.tsx", "stories/**/*.mdx"],
    "exclude": ["**/*.js", "./storybook-static/**", "./.storybook/**", "dist/**"]
}
