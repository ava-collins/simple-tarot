{
    "name": "@simpletarot/hooks",
    "version": "2.1.1",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./server": {
            "import": "./dist/server.js",
            "types": "./dist/server.d.ts"
        },
        "./client": {
            "import": "./dist/client.js",
            "types": "./dist/client.d.ts"
        }
    },
    "scripts": {
        "build-types": "rm -rf dist && tsc -b",
        "test": "vitest run --config vitetest.config.mjs --coverage",
        "semantic-release": "node ../../node_modules/semantic-release/bin/semantic-release.js"
    },
    "dependencies": {
        "@simpletarot/cards": "*"
    },
    "peerDependencies": {
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-native": "0.86.0"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.0",
        "@testing-library/react": "^16.3.0",
        "@types/jest": "^30.0.0",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/ui": "^3.2.4",
        "jsdom": "^26.1.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-native": "0.86.0",
        "typescript": "^6.0.3",
        "vitest": "^3.2.4"
    }
}
